{
  "_comment": "GD 标记注册表 — ND 写入 JSON 前查表确认标记已实现。M6 执行。",
  "markers": {
    "[shake]...[/shake]": { "status": "已实现", "engine": "main_window.py _extract_shake + _start_shake_animation", "limit": "≤3次/章" },
    "[pause N]": { "status": "已实现", "engine": "main_window.py _extract_pause + _start_pause", "params": "N=秒数(浮点)" },
    "[sound name]": { "status": "引擎已就绪，播放已暂停", "engine": "main_window.py _extract_sound + sound_manager.play()", "note": "音效全局暂停，待配表工具" },
    "multi_click": { "status": "已实现", "engine": "main.py cmd_choice + main_window.py update_choice_label(含渐变色)", "params": "count=次数, texts=[渐变文字]" },
    "text_bridges": { "status": "已实现", "engine": "story_engine.py get_current_text()", "params": "{node_id: bridge_text, *: fallback}" },
    "auto_next": { "status": "已实现", "engine": "story_engine.py _jump_to_node + main.py cmd_auto_advance" },
    "is_ending_chain": { "status": "已实现", "engine": "main_window.py show_chunked_text (只读模式)", "params": "boolean" },
    "is_ending_node": { "status": "已实现", "engine": "main.py _on_text_done → check_ending()" },
    "set_flags": { "status": "已实现", "engine": "story_engine.py make_choice + _jump_to_node + goto_node" },
    "conditions": { "status": "已实现", "engine": "state_manager.py check_condition()", "params": "{var: {min: N, max: M}}" },
    "effects": { "status": "已实现", "engine": "state_manager.py apply_effects()" },
    "mood": { "status": "已实现", "engine": "main_window.py MOOD_SPEEDS", "values": ["dread", "tension", "loss", "quiet"] },
    "text_bridges (按前置节点匹配)": { "status": "已实现", "engine": "story_engine.py get_current_text()" }
  }
}
